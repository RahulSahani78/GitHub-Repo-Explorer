# Port the API server listens on
PORT=4000

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# How long an issued login token stays valid
JWT_EXPIRES_IN=7d

# Optional: a GitHub Personal Access Token (classic, no scopes needed for public data).
# Without it, GitHub allows 60 unauthenticated requests/hour per IP.
# With it, the limit rises to 5,000 requests/hour. Used server-side only.
GITHUB_TOKEN=

# How long (in seconds) a GitHub response is served from the in-memory cache
CACHE_TTL_SECONDS=60

# Maximum number of repos to fetch per user (GitHub is paginated at 100/page)
MAX_REPOS=300
